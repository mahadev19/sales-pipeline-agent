# Sales Pipeline Agent — Environment Configuration
# Copy this file to .env and fill in your actual values.
# Never commit .env to version control.

# ---------------------------------------------------------------------------
# Google AI / Gemini Model Configuration
# ---------------------------------------------------------------------------

# Option A: Google AI Studio (local development)
GOOGLE_API_KEY=your_google_ai_studio_api_key_here
GOOGLE_GENAI_USE_VERTEXAI=False

# Option B: Google Vertex AI (production)
# GOOGLE_GENAI_USE_VERTEXAI=True
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=us-central1

# ---------------------------------------------------------------------------
# Web Search Tool (optional — pipeline works in stub mode without these)
# ---------------------------------------------------------------------------
# SEARCH_API_KEY=your_serpapi_or_custom_search_key
# SEARCH_ENGINE_ID=your_google_custom_search_engine_id

# ---------------------------------------------------------------------------
# CRM MCP Server
# ---------------------------------------------------------------------------
CRM_SERVER_URL=http://localhost:8001/sse
